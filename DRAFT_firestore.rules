rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidImageGeneration(data) {
      return data.keys().hasAll(['id', 'prompt', 'fullPrompt', 'imageData', 'createdAt', 'userId']) &&
             data.keys().size() == 6 &&
             data.id is string && data.id.size() <= 128 &&
             data.prompt is string && data.prompt.size() <= 1000 &&
             data.fullPrompt is string && data.fullPrompt.size() <= 10000 &&
             data.imageData is string && data.imageData.size() <= 1000000 &&
             data.userId == request.auth.uid;
    }

    match /generated_images/{imageId} {
      allow read: if isSignedIn(); // We can allow anyone signed in to view the global gallery
      
      allow create: if isSignedIn() &&
                    isValidId(imageId) &&
                    isValidImageGeneration(incoming()) &&
                    incoming().id == imageId &&
                    incoming().createdAt == request.time;
                    
      // Updates and deletes are not needed for this MVP, or we can allow the owner to delete.
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow update: if false;
    }
  }
}
